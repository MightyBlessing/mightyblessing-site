# Vercel(또는 로컬)에서 사이트 URL 지정 시 sitemap.xml, robots.txt에 반영됩니다.
# Vercel 배포 후 자동 부여되는 URL(예: https://mightyblessing-site.vercel.app)을 넣거나
# 커스텀 도메인 연결 시 해당 도메인을 넣으세요.
NEXT_PUBLIC_SITE_URL=https://mightyblessing.com

# Google Analytics 4 측정 ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-X195JMZNYZ

# Admin 인증
ADMIN_ID=admin
ADMIN_PASSWORD=admin1234
ADMIN_SESSION_SECRET=change-this-secret

# GitHub 연동 (배포 환경에서 admin 저장을 실제 저장소 커밋으로 연결할 때 사용)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main

# 문의 폼 메일 전송
# 둘 다 비워두면 문의 폼은 메일 작성창(mailto) fallback으로 동작합니다.
RESEND_API_KEY=
INQUIRY_FROM_EMAIL=
INQUIRY_TO_EMAIL=contact@mightyblessing.com
